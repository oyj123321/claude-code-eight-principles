{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "evaluation": {
      "type": "object",
      "properties": {
        "principle_id": {
          "type": "string",
          "enum": [
            "verify-before-assuming",
            "align-requirements",
            "ask-business-rules",
            "reuse-existing",
            "complete-tests",
            "follow-conventions",
            "admit-uncertainty",
            "iterate-incrementally"
          ],
          "description": "Which of the eight principles is being evaluated"
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "description": "0=violation, 1=minimally compliant, 2=mostly compliant, 3=fully compliant"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 5,
          "description": "1-5 direct quotes from the transcript supporting the score"
        },
        "summary": {
          "type": "string",
          "description": "One sentence explaining why this score was assigned"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Specific violations observed (empty array if score is 3)"
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Specific good behaviors observed (empty array if score is 0)"
        }
      },
      "required": ["principle_id", "score", "evidence", "summary", "violations", "highlights"],
      "additionalProperties": false
    }
  },
  "required": ["evaluation"],
  "additionalProperties": false
}
